generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VillageProfile {
  id                         String   @id @default(uuid())
  sejarah                    String
  visi                       String
  misi                       String[]
  sambutan_kepdes            String
  peta_url                   String?
  koordinat                  String?
  batas_desa                 String?
  luas_wilayah               String?
  jumlah_penduduk            Int?
  realisasi_dana_desa_persen Int      @default(0)
  umkm_aktif                 Int      @default(0)
  updatedAt                  DateTime @updatedAt
}

model StrukturOrganisasi {
  id           String  @id @default(uuid())
  jabatan      String
  nama_pejabat String
  urutan       Int     @default(0)
  foto_url     String?
}

model User {
  id       String @id @default(uuid())
  nama     String
  email    String @unique
  password String
  role     String @default("EDITOR")
  news     News[]
}

model News {
  id                String   @id @default(uuid())
  judul             String
  slug              String   @unique
  konten            String
  status            String   @default("DRAFT")
  tanggal_publikasi DateTime @default(now())
  cover_url         String?
  penulis_id        String
  penulis           User     @relation(fields: [penulis_id], references: [id])
}

model KatalogCategory {
  id      String    @id @default(uuid())
  nama    String
  icon    String?
  katalog Katalog[]
}

model Katalog {
  id         String          @id @default(uuid())
  nama       String
  slug       String          @unique
  deskripsi  String
  latitude   Float
  longitude  Float
  dusun      String?
  kontak     String?
  fotoUrl    String?
  categoryId String
  createdAt  DateTime        @default(now())
  category   KatalogCategory @relation(fields: [categoryId], references: [id])
}

model Galeri {
  id          String  @id @default(uuid())
  foto_url    String
  caption     String
  katalog_id  String?
  kegiatan_id String?
}

model Kegiatan {
  id        String @id @default(uuid())
  judul     String
  deskripsi String
  tanggal   String
  lokasi    String
}

model DocumentCategory {
  id        String     @id @default(uuid())
  name      String
  documents Document[]
}

model Document {
  id           String           @id @default(uuid())
  judul        String
  file_url     String
  size         String?
  format       String?
  published_at DateTime         @default(now())
  category_id  String
  category     DocumentCategory @relation(fields: [category_id], references: [id])
}

model Pengaduan {
  id           String   @id @default(uuid())
  nama_pelapor String
  kontak       String
  judul        String
  deskripsi    String
  status       String   @default("PENDING")
  created_at   DateTime @default(now())
}

model PendudukStat {
  id             String @id @default(uuid())
  tahun          Int    @unique
  total_penduduk Int
  laki_laki      Int
  perempuan      Int
  jumlah_kk      Int
}

model Apbdes {
  id               String @id @default(uuid())
  tahun            Int    @unique
  pendapatan       Float
  belanja          Float
  pembiayaan       Float
  kategori_belanja Json
}

model IdmSdgScore {
  id         String @id @default(uuid())
  tahun      Int    @unique
  skor_idm   Float
  status_idm String
  skor_sdgs  Float
}

model StuntingBansos {
  id              String @id @default(uuid())
  tahun           Int    @unique
  jumlah_stunting Int
  penerima_bansos Int
}
